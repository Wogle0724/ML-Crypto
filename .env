# MySQL
# Consumed by: mysql container (server init), backend/src/services/db.js,
#              pipeline/dags/fetch_prices.py and train_model.py (via SQLAlchemy + pymysql),
#              airflow-* services (AIRFLOW__DATABASE__SQL_ALCHEMY_CONN in docker-compose.yml)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=crypto_db
MYSQL_USER=crypto_user
MYSQL_PASSWORD=crypto_password

# Redis
# Consumed by: backend/src/services/redis.js (ioredis client)
REDIS_URL=redis://redis:6379

# MLflow
# Consumed by: ml-service/app/model/load.py (mlflow.set_tracking_uri)
#              pipeline/dags/train_model.py (mlflow.log_model, mlflow.log_metric)
MLFLOW_TRACKING_URI=http://mlflow:5000

# External APIs
# Consumed by: pipeline/dags/fetch_prices.py (fetch_from_coingecko task)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Service URLs (inter-container communication on crypto-net)
# BACKEND_URL    → frontend/vite.config.js dev-server proxy target
# ML_SERVICE_URL → backend/src/routes/predictions.js (axios.post to POST /predict)
BACKEND_URL=http://backend:4000
ML_SERVICE_URL=http://ml-service:8000

# Airflow
# AIRFLOW_FERNET_KEY → encrypts connection passwords stored in airflow_db (MySQL)
# AIRFLOW_SECRET_KEY → signs Flask session cookies for the Airflow webserver UI
# Both consumed by: airflow-init, airflow-webserver, airflow-scheduler (docker-compose.yml)
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGEME_generate_with_cryptography_fernet
AIRFLOW_SECRET_KEY=CHANGEME_random_secret_32_chars_min
